[
  {
    "name": "stable",
    "expectedState": "ok",
    "expectedReasons": [],
    "expectedSummary": "HPA is within configured bounds",
    "expectedTableState": "ok",
    "hpa": {
      "apiVersion": "autoscaling/v2",
      "kind": "HorizontalPodAutoscaler",
      "metadata": { "name": "web", "namespace": "default", "generation": 1 },
      "spec": {
        "scaleTargetRef": { "apiVersion": "apps/v1", "kind": "Deployment", "name": "web" },
        "minReplicas": 2,
        "maxReplicas": 10,
        "metrics": [
          { "type": "Resource", "resource": { "name": "cpu", "target": { "type": "Utilization", "averageUtilization": 70 } } }
        ]
      },
      "status": {
        "observedGeneration": 1,
        "currentReplicas": 4,
        "desiredReplicas": 4,
        "currentMetrics": [
          { "type": "Resource", "resource": { "name": "cpu", "current": { "averageUtilization": 55 } } }
        ],
        "conditions": [
          { "type": "AbleToScale", "status": "True", "reason": "SucceededGetScale" },
          { "type": "ScalingActive", "status": "True", "reason": "ValidMetricFound" },
          { "type": "ScalingLimited", "status": "False", "reason": "DesiredWithinRange" }
        ]
      }
    }
  },
  {
    "name": "maxed",
    "expectedState": "limited_max",
